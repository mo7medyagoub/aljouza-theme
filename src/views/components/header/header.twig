{#
| Variable         | Type    | Description                     |
|------------------|---------|---------------------------------|
| cart             | object  |                                 |
| cart.items_count | int     |                                 |
| cart.total       | string  | Formatted total ex: "١٠٠ ر.س"   |
#}
{% set important_links = theme.settings.get('important_links') %}
<header class="store-header relative z-50">
  
  {# 1. Top Nav (شريط علوي نحيف جداً للإشعارات والروابط السريعة) #}
  <div class="top-navbar">
    <div class="container flex justify-between items-center text-xs">
      <div class="flex-1 flex items-center gap-4">
          
          {% if important_links %}
            <salla-menu source="footer" topnav></salla-menu>
          {% endif %}

          <div class="header-buttons">
              {% if store.settings.is_multilingual or store.settings.currencies_enabled %}
                  <salla-localization-modal show-trigger></salla-localization-modal>
              {% endif %}
          </div>

          {% if store.scope %}
              <button class="text-gray-500 hover:text-primary transition-colors flex items-center gap-1"
                      onclick="salla.event.dispatch('scopes::open', {'mode': 'default'})">
                  <i class="sicon-location"></i> {{ store.scope.name }}
              </button>
          {% endif %}
      </div>

      <salla-contacts is-header></salla-contacts>
    </div>
  </div>

  {# 2. Main Nav (الهيدر الزجاجي العائم الأساسي) #}
  <div id="mainnav" class="main-nav-container w-full">
      <div class="inner">
          <div class="flex items-center justify-between w-full relative">
              
              {# الجزء الأيمن: الشعار وزر القائمة للجوال #}
              <div class="flex items-center gap-4">
                  <a class="lg:hidden mburger mburger--collapse leading-none" href="#mobile-menu" aria-label="Open-menu">
                    <i class="sicon-menu text-gray-700 text-2xl"></i>
                  </a>
                  <a class="navbar-brand hover:opacity-80 transition-opacity" href="{{ store.url }}">
                      <img fetchpriority="high" width="100%" height="100%" loading="eager" src="{{ store.logo|cdn(175) }}" alt="{{ store.name }} logo">
                      {% if is_page('index') %}
                        <h1 class="sr-only">{{ store.name }}</h1>
                      {% else %}
                        <h2 class="sr-only">{{ store.name }}</h2>
                      {% endif %}
                  </a>
              </div>

              {# الجزء الأوسط: القائمة الرئيسية (تختفي في الجوال وتظهر في الشاشات الكبيرة) #}
              <div class="hidden lg:flex items-center justify-center flex-1">
                  <custom-main-menu></custom-main-menu>
              </div>

              {# الجزء الأيسر: البحث، الحساب، وسلة المشتريات #}
              <div class="flex items-center justify-end gap-3 lg:gap-4">
                  
                  {# مربع البحث (تصميم بيضاوي متناسق مع أبل) #}
                  <div class="header-search hidden sm:block w-48 lg:w-64">
                    <salla-search inline oval height="40"></salla-search>
                  </div>
                  
                  <salla-user-menu avatar-only show-header show-trigger class="hover:scale-105 transition-transform duration-300"></salla-user-menu>
                  
                  <salla-cart-summary class="hover:scale-105 transition-transform duration-300 ml-2 rtl:ml-[unset] rtl:mr-2">
                    <i slot="icon" class="header-btn__icon icon sicon-shopping-bag"></i>
                  </salla-cart-summary>
              </div>

          </div>
      </div>
  </div>
</header>